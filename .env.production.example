DJANGO_SETTINGS_MODULE=config.settings.production
DEBUG=False

# Core
SECRET_KEY=replace-with-a-long-random-secret-key
ALLOWED_HOSTS=api.tudominio.com
FRONTEND_URL=https://app.tudominio.com
CORS_ALLOWED_ORIGINS=https://app.tudominio.com
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
ADMIN_URL=vendly-admin-2026/

# Database
USE_SQLITE=False
DB_NAME=vendly
DB_USER=vendly_user
DB_PASSWORD=replace-with-a-strong-db-password
DB_HOST=postgres
DB_PORT=5432

# Realtime / queues
USE_INMEMORY_CHANNEL_LAYER=False
USE_LOCMEM_CACHE=False
CELERY_TASK_ALWAYS_EAGER=False
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=django-db

# AI
ENABLE_REAL_AI=True
OPENAI_API_KEY=replace-with-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_ROUTER_MODEL=gpt-4.1-nano
OPENAI_SALES_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# WhatsApp / Meta
ENABLE_REAL_WHATSAPP=True
META_APP_ID=
META_APP_SECRET=
META_EMBEDDED_SIGNUP_CONFIG_ID=
WHATSAPP_VERIFY_TOKEN=replace-with-a-random-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v19.0
WHATSAPP_BASE_URL=https://graph.facebook.com

# Email
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@tudominio.com

# Storage / observability
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
APP_VERSION=2.0.0
